#!/usr/bin/env bash
# tu-agent shim: resolves the real binary, auto-installing it from GitHub Releases
# on first use if it is missing. The plugin never ships a compiled binary, so this
# is the single chokepoint every plugin call (MCP server + hooks) goes through.
#
# Resolution order:
#   1. `tu-agent` already on PATH (excluding this shim's own dir)
#   2. a previously auto-installed binary at ~/.tu-agent/bin/tu-agent
#   3. download the matching binary from the latest GitHub Release and install it
#
# Env knobs:
#   TU_AGENT_RELEASE_REPO       owner/repo to fetch releases from (default below)
#   TU_AGENT_NO_AUTO_INSTALL=1  never download; error out instead
set -euo pipefail

RELEASE_REPO="${TU_AGENT_RELEASE_REPO:-carlosneir4/tu-agent}"
INSTALL_DIR="${HOME}/.tu-agent/bin"
INSTALL_BIN="${INSTALL_DIR}/tu-agent"

# Exclude this shim's own directory from PATH to prevent circular execution when
# the plugin host adds plugin/bin to PATH.
SHIM_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLEAN_PATH="$(printf '%s' "$PATH" | tr ':' '\n' | grep -vxF "$SHIM_DIR" | tr '\n' ':' | sed 's/:$//')"

# 1. real tu-agent already on PATH
if PATH="$CLEAN_PATH" command -v tu-agent >/dev/null 2>&1; then
  exec env PATH="$CLEAN_PATH" tu-agent "$@"
fi
# 2. previously auto-installed
if [ -x "$INSTALL_BIN" ]; then
  exec "$INSTALL_BIN" "$@"
fi

manual_help() {
  cat >&2 <<EOF
tu-agent binary not found and could not be auto-installed.
Install it manually, either:
  go install -tags sqlite_fts5 github.com/tu/tu-agent/cmd/tu-agent@latest
or download the asset for your platform from
  https://github.com/${RELEASE_REPO}/releases
and place it at ${INSTALL_BIN} (chmod +x).
EOF
  exit 127
}

# 3. auto-install (unless opted out)
if [ "${TU_AGENT_NO_AUTO_INSTALL:-0}" = "1" ]; then
  echo "tu-agent: binary not found and auto-install is disabled (TU_AGENT_NO_AUTO_INSTALL=1)." >&2
  manual_help
fi

os="$(uname -s)"
arch="$(uname -m)"
case "$os" in
  Darwin) goos="darwin" ;;
  Linux) goos="linux" ;;
  *)
    echo "tu-agent: unsupported OS for auto-install: $os" >&2
    manual_help
    ;;
esac
case "$arch" in
  arm64 | aarch64) goarch="arm64" ;;
  x86_64 | amd64) goarch="amd64" ;;
  *)
    echo "tu-agent: unsupported architecture for auto-install: $arch" >&2
    manual_help
    ;;
esac

asset="tu-agent-${goos}-${goarch}.tar.gz"
base="https://github.com/${RELEASE_REPO}/releases/latest/download"

command -v curl >/dev/null 2>&1 || {
  echo "tu-agent: curl is required for auto-install" >&2
  manual_help
}

tmp="$(mktemp -d)"
trap 'rm -rf "$tmp"' EXIT
echo "tu-agent: first run — installing ${asset} from ${RELEASE_REPO}..." >&2

if ! curl -fsSL "${base}/${asset}" -o "${tmp}/${asset}"; then
  echo "tu-agent: download failed: ${base}/${asset}" >&2
  manual_help
fi

# Verify the checksum against the release SHA256SUMS when available.
if curl -fsSL "${base}/SHA256SUMS" -o "${tmp}/SHA256SUMS" 2>/dev/null; then
  want="$(grep " ${asset}\$" "${tmp}/SHA256SUMS" | awk '{print $1}' || true)"
  if [ -n "$want" ]; then
    if command -v sha256sum >/dev/null 2>&1; then
      got="$(sha256sum "${tmp}/${asset}" | awk '{print $1}')"
    else
      got="$(shasum -a 256 "${tmp}/${asset}" | awk '{print $1}')"
    fi
    if [ "$want" != "$got" ]; then
      echo "tu-agent: checksum mismatch for ${asset} (want ${want}, got ${got})" >&2
      manual_help
    fi
  fi
fi

if ! tar -C "$tmp" -xzf "${tmp}/${asset}" tu-agent 2>/dev/null; then
  echo "tu-agent: failed to extract ${asset}" >&2
  manual_help
fi
mkdir -p "$INSTALL_DIR"
mv "${tmp}/tu-agent" "$INSTALL_BIN"
chmod +x "$INSTALL_BIN"
echo "tu-agent: installed at ${INSTALL_BIN}" >&2
exec "$INSTALL_BIN" "$@"
