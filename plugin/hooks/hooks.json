{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/tu-agent graph update --quiet"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "TU_AGENT_UPDATE_INTERVAL=0 ${CLAUDE_PLUGIN_ROOT}/bin/tu-agent graph update --quiet"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/tu-agent memory import --quiet"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/tu-agent memory relink --quiet"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/tu-agent memory export --quiet"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/tu-agent memory export --quiet"
          }
        ]
      }
    ]
  }
}
