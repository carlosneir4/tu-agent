{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/tu-agent graph update --quiet || exit 0"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/tu-agent hook edit-check || exit 0"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/tu-agent graph update --post-bash || exit 0"
          }
        ]
      },
      {
        "matcher": "mcp__playwright",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/tu-agent hook mcp-action || exit 0"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/tu-agent hook prompt-submit || exit 0"
          }
        ]
      }
    ],
    "UserPromptExpansion": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/tu-agent hook prompt-expansion || exit 0"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/tu-agent graph update --quiet --announce || exit 0"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/tu-agent memory import --quiet || exit 0"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/tu-agent memory relink --quiet || exit 0"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/tu-agent memory materialize --quiet || exit 0"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/tu-agent advise --nudge || exit 0"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/tu-agent hook session-rules || exit 0"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/tu-agent memory export --quiet || exit 0"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/tu-agent memory export --quiet || exit 0"
          }
        ]
      }
    ]
  }
}
