bench/runs/

# fixture runtime artifacts (graph store, telemetry, etc.)
scripts/fixtures/**/.tu-agent/
scripts/fixtures/**/node_modules/
scripts/fixtures/**/package-lock.json

# >>> tu-agent >>>
# Default-deny: ignore every tu-agent artifact; re-include only the shared
# subtree. git cannot re-include a path under an excluded directory in one step,
# so .tu-agent/share/ (holding the team-shared memory chunks) is re-included as a
# whole; graph.db, memory.db, telemetry and every future artifact stay local.
.tu-agent/*
!.tu-agent/share/
.claude/settings.json.bak
# <<< tu-agent <<<
